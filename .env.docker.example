# App settings
APP_PORT=5000
NODE_ENV=production
SESSION_SECRET=replace-with-a-long-random-secret-32-chars-min

# Database connection used by app + migrate service
DATABASE_URL=postgresql://postgres:postgres@db:5432/shiftflow

# PostgreSQL container settings
DB_PORT=5432
POSTGRES_DB=shiftflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
